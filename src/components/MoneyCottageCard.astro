---
/**
 * One cottage card for the cross-cutting "money" pages (enclosed gardens, 2+
 * dogs, muddy dogs, large cottages). Leads with a page-specific highlight line,
 * then the booking CTA and a link to the full regional review.
 */
import type { CollectionEntry } from 'astro:content';
import AffiliateCTA from './AffiliateCTA.astro';

interface Props {
  listing: CollectionEntry<'listings'>;
  /** Short label for the feature this page filters on, e.g. "Garden", "Dogs". */
  highlightLabel: string;
  /** The verified detail for that feature on this property. */
  highlightValue: string;
}

const { listing: c, highlightLabel, highlightValue } = Astro.props;
const slug = c.id.split('/').pop()!;

// Full review lives on the regional cottages listicle, or the hot-tub money
// page for the tagged lodges (which aren't on a regional cottages page).
const fullReviewHref = c.data.tags.includes('hot-tub')
  ? `/dog-friendly-hot-tub-lodges/#${slug}`
  : `/${c.data.region}/cottages/#${slug}`;
---
<article id={slug} class="scroll-mt-8 flex flex-col bg-cream-soft border border-edge">
  <div class="aspect-[16/11] overflow-hidden bg-cream-soft border-b border-edge">
    <img src={c.data.image} alt={c.data.image_alt ?? c.data.name} loading="lazy" class="h-full w-full object-cover" />
  </div>
  <div class="flex flex-col flex-1 p-5">
    <p class="eyebrow">{c.data.town}</p>
    <h3 class="mt-1">{c.data.name}</h3>
    <p class="mt-3 text-sm">
      <span class="eyebrow text-forest">{highlightLabel}</span><br />
      {highlightValue}
    </p>
    <p class="mt-3 text-sm text-muted">
      Sleeps {c.data.sleeps}
      {c.data.bedrooms && ` · ${c.data.bedrooms} bed${c.data.bedrooms === 1 ? '' : 's'}`}
      {c.data.price_indicator && ` · ${c.data.price_indicator}`}
    </p>
    <div class="mt-auto pt-5">
      <AffiliateCTA
        provider={c.data.affiliate_provider}
        identifier={slug}
        fallbackUrl={c.data.external_url ?? undefined}
      />
      <p class="mt-3 text-sm">
        <a href={fullReviewHref} class="text-text">Full review →</a>
      </p>
    </div>
  </div>
</article>
