---
import type { CollectionEntry } from 'astro:content';

interface Props {
  region: CollectionEntry<'regions'>;
  count?: number;
  href?: string;
}

const { region, count, href } = Astro.props;
const data = region.data;
const linkHref = href ?? `/${region.id}/`;
---
<a href={linkHref} class="group block no-underline">
  <div class="aspect-[3/4] overflow-hidden bg-edge">
    <img
      src={data.hero_image}
      alt=""
      loading="lazy"
      class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.02]"
    />
  </div>
  <div class="pt-4">
    <h3 class="mb-1 group-hover:text-clay-deep transition-colors">{data.name}</h3>
    {count !== undefined && (
      <p class="text-sm text-muted">
        {count} dog-friendly {count === 1 ? 'place' : 'places'}
      </p>
    )}
  </div>
</a>
