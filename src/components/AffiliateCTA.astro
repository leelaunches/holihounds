---
/**
 * Renders the booking CTA. The href resolves via `affiliateHref()` to a tracked
 * Awin deeplink when the provider is an approved Awin merchant, otherwise to the
 * property's own booking page (working, but untracked). See src/lib/affiliate.ts.
 */
import { affiliateHref } from '~/lib/affiliate';

interface Props {
  provider: string | null;
  /** Listing slug — surfaced as a data attribute for analytics, not used in the URL. */
  identifier: string;
  /** The property's own booking URL (listing `external_url`). */
  fallbackUrl?: string;
  label?: string;
}

const { provider, identifier, fallbackUrl, label = 'Check availability' } = Astro.props;
const href = affiliateHref(provider ?? null, fallbackUrl ?? null);
---
<a
  href={href}
  rel="sponsored nofollow noopener"
  target="_blank"
  data-affiliate-provider={provider}
  data-listing={identifier}
  class="inline-flex items-center justify-center bg-clay px-6 py-3.5 text-white no-underline font-medium transition-colors hover:bg-clay-deep"
>
  {label}
</a>
