---
import type { CollectionEntry } from 'astro:content';

interface Props {
  listing: CollectionEntry<'listings'>;
  href: string;
}

const { listing, href } = Astro.props;
const data = listing.data;
const sleepsLine =
  data.sleeps && data.bedrooms
    ? `Sleeps ${data.sleeps} · ${data.bedrooms} bed${data.bedrooms === 1 ? '' : 's'}`
    : data.sleeps
      ? `Sleeps ${data.sleeps}`
      : null;
---
{/*
  Card-as-link pattern: the entire card is one anchor. The H3 cottage name is
  the implicit click affordance (clay-deep on hover). No per-card CTA button —
  reserves the clay accent for the affiliate CTAs inside each individual
  listing's full entry on the listicle page.
*/}
<a
  href={href}
  class="group flex flex-col h-full no-underline bg-cream-soft border border-edge overflow-hidden"
>
  <div class="aspect-[16/11] overflow-hidden">
    <img
      src={data.image}
      alt={data.image_alt ?? data.name}
      loading="lazy"
      class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.02]"
    />
  </div>
  <div class="flex flex-1 flex-col gap-3 p-6">
    <p class="eyebrow">{data.town} · {data.type}</p>
    <h3 class="text-xl group-hover:text-clay-deep transition-colors">
      {data.name}
    </h3>
    <p class="text-sm line-clamp-2">{data.description}</p>
    <div class="mt-auto flex items-center justify-between text-sm pt-2">
      {sleepsLine && <span class="text-muted">{sleepsLine}</span>}
      <span class="text-muted">{data.price_indicator}</span>
    </div>
  </div>
</a>
